<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Title -->
    <TextView
        android:text="Calculate Tip"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ===== CARD BILL ===== -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#EDE7F6"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Bill Amount"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etBill"
            android:hint="Masukkan jumlah bill"
            android:inputType="numberDecimal"
            android:background="@android:color/transparent"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ===== CARD TIP ===== -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#EDE7F6"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Tip Percentage"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Switch Row -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Round up tip?"
            android:textSize="16sp"
            android:textColor="#444444"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Switch
            android:id="@+id/switchRound"
            android:layout_width="60dp"
            android:layout_height="35dp"
            android:scaleX="1.3"
            android:scaleY="1.3"
            android:thumbTint="@color/switch_thumb"
            android:trackTint="@color/switch_track"/>
    </LinearLayout>

    <!-- Result -->
    <TextView
        android:id="@+id/tvResult"
        android:text="Tip Amount: $0.00"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="28dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>